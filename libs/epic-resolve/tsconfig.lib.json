{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "emitDeclarationOnly": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["src/**/*.spec.ts", "src/gh-fixtures.ts", "vitest.config.mts"],
  "references": [
    {
      "path": "../workspace/tsconfig.lib.json"
    },
    {
      "path": "../close-migration/tsconfig.lib.json"
    }
  ]
}
