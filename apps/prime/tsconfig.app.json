{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["dom", "es2022"],
    "types": [
      "node",
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts",
      "vite/client"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDirs": [".", "./.react-router/types"]
  },
  "exclude": [
    "out-tsc",
    "dist",
    "build",
    "app/**/*.spec.ts",
    "app/**/*.test.ts",
    "app/**/*.spec.tsx",
    "app/**/*.test.tsx",
    "app/**/*.spec.js",
    "app/**/*.test.js",
    "app/**/*.spec.jsx",
    "app/**/*.test.jsx",
    "server/**/*.spec.ts",
    "vitest.config.mts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "include": [
    ".react-router/types/**/*",
    "app/**/*.js",
    "app/**/*.jsx",
    "app/**/*.ts",
    "app/**/*.tsx",
    "server/**/*.ts",
    "server.ts",
    "vite.config.ts",
    "react-router.config.ts"
  ],
  "references": [
    {
      "path": "../../libs/editor/tsconfig.lib.json"
    }
  ]
}
